# IE-Eff — Environment Variables
# Copy to `.env` and fill in. `.env` is in .gitignore — DO NOT commit it.
# All vars marked REQUIRED must be set or the stack refuses to start.

# ── Database ────────────────────────────────────────────────────────────────
DB_NAME=shoe_eff_db
DB_USERNAME=ie_app
DB_PASSWORD=                       # REQUIRED — strong random, 24+ chars

# Used by the app JAR when running bare-metal (compose builds DB_URL itself).
DB_URL=jdbc:postgresql://localhost:5432/shoe_eff_db

# ── Seed application users (consumed only on first boot) ────────────────────
APP_DEFAULT_ADMIN_PASSWORD=        # REQUIRED — change after first login
APP_DEFAULT_MANAGER_PASSWORD=      # REQUIRED — change after first login

# ── Networking / runtime ────────────────────────────────────────────────────
APP_PORT=8080
MANAGEMENT_PORT=8081
HTTP_PORT=80
HTTPS_PORT=443
TZ=Asia/Ho_Chi_Minh
