# IE-Eff — Environment Variables
# Copy file này và điền giá trị thực vào khi deploy production.
# File .env.example này KHÔNG chứa thông tin nhạy cảm — an toàn để commit.

# ─── Database ─────────────────────────────────────────────────────────────────
# JDBC URL cho SQL Server. Thay your-server bằng hostname/IP thực tế.
DB_URL=jdbc:sqlserver://your-server:1433;databaseName=ShoeEffDB;encrypt=true;trustServerCertificate=true

# Tài khoản SQL Server
DB_USERNAME=sa
DB_PASSWORD=your_strong_password_here

# ─── Server ───────────────────────────────────────────────────────────────────
# Port ứng dụng lắng nghe (mặc định 8080 nếu không set)
PORT=8080
